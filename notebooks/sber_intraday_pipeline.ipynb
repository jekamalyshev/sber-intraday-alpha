   "source": ["## Cell 2 — Helper: series_to_supervised"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-2",
   "metadata": {},
   "outputs": [],
   "source": [
    "def series_to_supervised(data, n_in=1, n_out=1, dropnan=True):\n",
    "    n_vars = 1 if type(data) is list else data.shape[1]\n",
    "    df = DataFrame(data)\n",
    "    col_list = data.columns.tolist()\n",
    "    cols, names = list(), list()\n",
    "    for i in range(n_in, 0, -1):\n",
    "        cols.append(df.shift(i))\n",
    "        names += [('%s_%d(t-%d)' % (col_list[j], j+1, i)) for j in range(n_vars)]\n",
    "    for i in range(0, n_out):\n",
    "        cols.append(df.shift(-i))\n",
    "        if i == 0:\n",
    "            names += [('%s_var%d(t)' % (col_list[j], j+1)) for j in range(n_vars)]\n",
    "        else:\n",
    "            names += [('%s_var%d(t+%d)' % (col_list[j], j+1, i)) for j in range(n_vars)]\n",
    "    agg = concat(cols, axis=1)\n",
    "    agg.columns = names\n",
    "    if dropnan:\n",
    "        agg.dropna(inplace=True)\n",
    "    return agg\n",
    "\n",
    "print('series_to_supervised defined ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "md-cell3",
   "metadata": {},
   "source": ["## Cell 3 — Feature Engineering Functions"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-3",
   "metadata": {},
   "outputs": [],
   "source": [
    "EPS = 1e-12\n",
    "\n",
    "def prepare_ohlcv_dataframe(df):\n",
    "    required = {'OPEN', 'HIGH', 'LOW', 'CLOSE', 'VOL'}\n",
    "    missing = required.difference(df.columns)\n",
    "    if missing:\n",
    "        raise ValueError(f'Missing required columns: {sorted(missing)}')\n",
    "    out = df.copy(deep=True)\n",
    "    for col in ['OPEN', 'HIGH', 'LOW', 'CLOSE', 'VOL']:\n",
    "        out[col] = pd.to_numeric(out[col], errors='coerce')\n",
    "    if {'DATE', 'TIME'}.issubset(out.columns):\n",
    "        date_str = out['DATE'].astype(str).str.strip()\n",
    "        time_str = out['TIME'].astype(str).str.zfill(6).str.strip()\n",
    "        out['datetime'] = pd.to_datetime(date_str + time_str, format='%Y%m%d%H%M%S', errors='coerce')\n",
    "        out = out.sort_values('datetime', kind='stable').reset_index(drop=True)\n",
    "    return out\n",
    "\n",
    "\n",
    "def add_domain_features(df):\n",
    "    out = df.copy(deep=True)\n",
    "    rng = out['HIGH'] - out['LOW']\n",
    "    safe_rng = rng.where(rng.abs() > EPS, np.nan)\n",
    "    max_oc = np.maximum(out['OPEN'], out['CLOSE'])\n",
    "    min_oc = np.minimum(out['OPEN'], out['CLOSE'])\n",
    "    prev_close = out['CLOSE'].shift(1)\n",
    "    prev_high  = out['HIGH'].shift(1)\n",
    "    prev_low   = out['LOW'].shift(1)\n",
    "    # ── Свечная геометрия ──────────────────────────────────────────\n",
    "    out['candle_body']         = out['CLOSE'] - out['OPEN']\n",
    "    out['body_abs']            = out['candle_body'].abs()\n",
    "    out['candle_range']        = rng\n",
    "    out['upper_wick']          = out['HIGH'] - max_oc\n",
    "    out['lower_wick']          = min_oc - out['LOW']\n",
    "    out['body_to_range']       = (out['body_abs'] / safe_rng).clip(0, 1)\n",
    "    out['upper_wick_to_range'] = (out['upper_wick'] / safe_rng).clip(0, 1)\n",
    "    out['lower_wick_to_range'] = (out['lower_wick'] / safe_rng).clip(0, 1)\n",
    "    out['close_pos_in_range']  = ((out['CLOSE'] - out['LOW']) / safe_rng).clip(0, 1)\n",
    "    out['open_pos_in_range']   = ((out['OPEN'] - out['LOW']) / safe_rng).clip(0, 1)\n",
    "    # ── Направление и паттерн ──────────────────────────────────────────\n",
    "    out['direction']           = np.sign(out['candle_body']).astype('float64')\n",
    "    out['is_green']            = (out['CLOSE'] > out['OPEN']).astype('int8')\n",
    "    out['is_red']              = (out['CLOSE'] < out['OPEN']).astype('int8')\n",
    "    out['is_doji_like']        = (out['body_to_range'] <= 0.1).astype('int8')\n",
    "    out['is_marubozu']         = (out['body_to_range'] >= 0.9).astype('int8')\n",
    "    out['is_hammer']           = ((out['lower_wick_to_range'] >= 0.6) & (out['body_to_range'] <= 0.3)).astype('int8')\n",
    "    out['is_inverted_hammer']  = ((out['upper_wick_to_range'] >= 0.6) & (out['body_to_range'] <= 0.3)).astype('int8')\n",
    "    # ── Returns ────────────────────────────────────────────────────────────\n",
    "    out['ret_1']               = out['CLOSE'].pct_change(1)\n",
    "    out['log_ret_1']           = np.log(out['CLOSE'] / out['CLOSE'].shift(1))\n",
    "    out['gap_from_prev_close'] = out['OPEN'] / prev_close - 1.0\n",
    "    out['close_to_prev_high']  = out['CLOSE'] / prev_high - 1.0\n",
    "    out['close_to_prev_low']   = out['CLOSE'] / prev_low - 1.0\n",
    "    out['hl_to_prev_range']    = rng / (prev_high - prev_low).replace(0, np.nan)\n",
    "    # ── Волатильность свечи ─────────────────────────────────────────────\n",
    "    out['range_pct_close']     = out['candle_range'] / out['CLOSE'].replace(0, np.nan)\n",
    "    out['range_pct_open']      = out['candle_range'] / out['OPEN'].replace(0, np.nan)\n",
    "    # ── Volume ─────────────────────────────────────────────────────────────\n",
    "    out['body_x_vol']          = out['body_abs'] * out['VOL']\n",
    "    out['signed_vol']          = out['direction'] * out['VOL']\n",
    "    out['money_flow_proxy']    = ((out['CLOSE'] - out['LOW']) - (out['HIGH'] - out['CLOSE'])) / safe_rng * out['VOL']\n",
    "    out['vol_chg_1']           = out['VOL'].pct_change(1)\n",
    "    return out\n",
    "\n",
    "\n",
    "def add_rolling_features(df, windows=(6, 12, 24)):\n",
    "    out = df.copy(deep=True)\n",
    "    for w in windows:\n",
    "        out[f'ret_{w}']           = out['CLOSE'].pct_change(w)\n",
    "        out[f'log_ret_{w}']       = np.log(out['CLOSE'] / out['CLOSE'].shift(w))\n",
    "        rng_mean = out['candle_range'].rolling(w, min_periods=w).mean()\n",
    "        rng_std  = out['candle_range'].rolling(w, min_periods=w).std()\n",
    "        out[f'range_mean_{w}']    = rng_mean\n",
    "        out[f'range_std_{w}']     = rng_std\n",
    "        out[f'range_zscore_{w}']  = (out['candle_range'] - rng_mean) / rng_std.replace(0, np.nan)\n",
    "        out[f'body_mean_{w}']     = out['body_abs'].rolling(w, min_periods=w).mean()\n",
    "        close_ma  = out['CLOSE'].rolling(w, min_periods=w).mean()\n",
    "        close_std = out['CLOSE'].rolling(w, min_periods=w).std()\n",
    "        out[f'close_ma_{w}']      = close_ma\n",
    "        out[f'close_vs_ma_{w}']   = out['CLOSE'] / close_ma - 1.0\n",
    "        out[f'close_zscore_{w}']  = (out['CLOSE'] - close_ma) / close_std.replace(0, np.nan)\n",
    "        vol_ma = out['VOL'].rolling(w, min_periods=w).mean()\n",
    "        vol_std = out['VOL'].rolling(w, min_periods=w).std()\n",
    "        out[f'vol_ma_{w}']        = vol_ma\n",
    "        out[f'vol_ratio_{w}']     = out['VOL'] / vol_ma.replace(0, np.nan)\n",
    "        out[f'vol_zscore_{w}']    = (out['VOL'] - vol_ma) / vol_std.replace(0, np.nan)\n",
    "        # Максимум / минимум High/Low за окно\n",
    "        rolling_high = out['HIGH'].rolling(w, min_periods=w).max()\n",
    "        rolling_low  = out['LOW'].rolling(w, min_periods=w).min()\n",
    "        out[f'high_max_{w}']      = rolling_high\n",
    "        out[f'low_min_{w}']       = rolling_low\n",
    "        out[f'close_vs_high_{w}'] = out['CLOSE'] / rolling_high - 1.0\n",
    "        out[f'close_vs_low_{w}']  = out['CLOSE'] / rolling_low - 1.0\n",
    "        # Green/Red bar ratio\n",
    "        out[f'green_ratio_{w}']   = out['is_green'].rolling(w, min_periods=w).mean()\n",
    "    return out\n",
    "\n",
    "\n",
    "def add_calendar_features(df):\n",
    "    if 'datetime' not in df.columns:\n",
    "        raise ValueError(\"Column 'datetime' not found. Run prepare_ohlcv_dataframe first.\")\n",
    "    out = df.copy(deep=True)\n",
    "    dt = out['datetime']\n",
    "    out['hour']        = dt.dt.hour\n",
    "    out['minute']      = dt.dt.minute\n",
    "    out['dayofweek']   = dt.dt.dayofweek\n",
    "    out['hour_sin']    = np.sin(2 * np.pi * out['hour'] / 24)\n",
    "    out['hour_cos']    = np.cos(2 * np.pi * out['hour'] / 24)\n",
    "    out['dow_sin']     = np.sin(2 * np.pi * out['dayofweek'] / 5)\n",
    "    out['dow_cos']     = np.cos(2 * np.pi * out['dayofweek'] / 5)\n",
    "    out['minutes_from_session_open'] = out['hour'] * 60 + out['minute'] - 600\n",
    "    out['is_opening_30m']  = (out['minutes_from_session_open'] < 30).astype('int8')\n",
    "    out['is_first_hour']   = (out['minutes_from_session_open'] < 60).astype('int8')\n",
    "    out['is_closing_30m']  = (out['minutes_from_session_open'] >= 390).astype('int8')\n",
    "    out['date_only'] = dt.dt.date\n",
    "    out['bar_in_day'] = out.groupby('date_only').cumcount()\n",
    "    out['is_first_bar_of_day'] = (out['bar_in_day'] == 0).astype('int8')\n",
    "    out = out.drop(columns=['date_only'])\n",
    "    return out\n",
    "\n",
    "\n",
    "def add_ta_features(df):\n",
    "    \"\"\"Comprehensive pandas-ta feature set.\n",
    "\n",
    "    Covers: trend (EMA/SMA/WMA/DEMA/TEMA/HMA/VWMA/KAMA), momentum\n",
    "    (RSI/CCI/MOM/ROC/Williams%R/CMF/MFI/PPO/AROON/UO/Stoch/StochRSI/TRIX/DPO),\n",
    "    volatility (ATR/NATR/BBands/Keltner/Donchian/MASSI/ATRTS),\n",
    "    volume (OBV/VWAP/AD/ADOSC/CMF/EFI/KVO/NVI/PVI),\n",
    "    trend-strength (ADX+DI), overlap (MIDPRICE/MIDPOINT/T3),\n",
    "    derived distance-from-indicator features.\n",
    "    \"\"\"\n",
    "    out = df.copy(deep=True)\n",
    "    c = out['CLOSE']; h = out['HIGH']; l = out['LOW']; v = out['VOL']\n",
    "    op = out['OPEN']\n",
    "\n",
    "    # ── TREND / MOVING AVERAGES ──────────────────────────────────────────\n",
    "    for length in [5, 10, 20, 50]:\n",
    "        out[f'ema_{length}']  = ta.ema(c, length=length)\n",
    "        out[f'sma_{length}']  = ta.sma(c, length=length)\n",
    "        out[f'wma_{length}']  = ta.wma(c, length=length)\n",
    "        out[f'hma_{length}']  = ta.hma(c, length=length)\n",
    "        out[f'c_vs_ema_{length}']  = c / out[f'ema_{length}'] - 1.0\n",
    "        out[f'c_vs_sma_{length}']  = c / out[f'sma_{length}'] - 1.0\n",
    "    # DEMA / TEMA (length=20)\n",
    "    out['dema_20'] = ta.dema(c, length=20)\n",
    "    out['tema_20'] = ta.tema(c, length=20)\n",
    "    out['kama_10'] = ta.kama(c, length=10)\n",
    "    out['c_vs_dema_20'] = c / out['dema_20'] - 1.0\n",
    "    out['c_vs_tema_20'] = c / out['tema_20'] - 1.0\n",
    "    out['c_vs_kama_10'] = c / out['kama_10'] - 1.0\n",
    "    # EMA crossovers\n",
    "    out['ema5_vs_ema20']  = out['ema_5']  / out['ema_20'] - 1.0\n",
    "    out['ema10_vs_ema50'] = out['ema_10'] / out['ema_50'] - 1.0\n",
    "    # VWMA\n",
    "    out['vwma_20'] = ta.vwma(c, v, length=20)\n",
    "    out['c_vs_vwma_20'] = c / out['vwma_20'] - 1.0\n",
    "\n",
    "    # ── MOMENTUM ────────────────────────────────────────────────────────\n",
    "    for length in [7, 14, 21]:\n",
    "        out[f'rsi_{length}'] = ta.rsi(c, length=length)\n",
    "        out[f'cci_{length}'] = ta.cci(h, l, c, length=length)\n",
    "        out[f'roc_{length}'] = ta.roc(c, length=length)\n",
    "        out[f'mom_{length}'] = ta.mom(c, length=length)\n",
    "    out['willr_14'] = ta.willr(h, l, c, length=14)\n",
    "    out['uo']       = ta.uo(h, l, c)\n",
    "    out['dpo_20']   = ta.dpo(c, length=20)\n",
    "    out['trix_15']  = ta.trix(c, length=15)\n",
    "    # MACD variants\n",
    "    for fast, slow, sig in [(12, 26, 9), (5, 13, 5)]:\n",
    "        tag = f'{fast}_{slow}_{sig}'\n",
    "        macd = ta.macd(c, fast=fast, slow=slow, signal=sig)\n",
    "        if macd is not None:\n",
    "            macd.columns = [f'macd_{tag}', f'macdh_{tag}', f'macds_{tag}']\n",
    "            out = pd.concat([out, macd], axis=1)\n",
    "    # PPO\n",
    "    ppo = ta.ppo(c)\n",
    "    if ppo is not None: out = pd.concat([out, ppo.add_prefix('ppo_')], axis=1)\n",
    "    # AROON\n",
    "    aroon = ta.aroon(h, l, length=14)\n",
    "    if aroon is not None: out = pd.concat([out, aroon.add_prefix('aroon_')], axis=1)\n",
    "    # Stochastic\n",
    "    stoch = ta.stoch(h, l, c, k=14, d=3, smooth_k=3)\n",
    "    if stoch is not None: out = pd.concat([out, stoch.add_prefix('stoch_')], axis=1)\n",
    "    # StochRSI\n",
    "    stochrsi = ta.stochrsi(c, length=14)\n",
    "    if stochrsi is not None: out = pd.concat([out, stochrsi.add_prefix('stochrsi_')], axis=1)\n",
    "\n",
    "    # ── VOLATILITY ───────────────────────────────────────────────────────\n",
    "    for length in [7, 14, 21]:\n",
    "        out[f'atr_{length}']  = ta.atr(h, l, c, length=length)\n",
    "        out[f'natr_{length}'] = ta.natr(h, l, c, length=length)\n",
    "    # Bollinger Bands\n",
    "    for length in [10, 20]:\n",
    "        bb = ta.bbands(c, length=length, std=2.0)\n",
    "        if bb is not None:\n",
    "            bb.columns = [f'bbl_{length}', f'bbm_{length}', f'bbu_{length}', f'bbb_{length}', f'bbp_{length}']\n",
    "            out = pd.concat([out, bb], axis=1)\n",
    "            bb_rng = (out[f'bbu_{length}'] - out[f'bbl_{length}']).replace(0, np.nan)\n",
    "            out[f'c_in_bb_{length}'] = (c - out[f'bbl_{length}']) / bb_rng\n",
    "    # Keltner Channel\n",
    "    kc = ta.kc(h, l, c, length=20)\n",
    "    if kc is not None: out = pd.concat([out, kc.add_prefix('kc_')], axis=1)\n",
    "    # Donchian Channel\n",
    "    dc = ta.donchian(h, l, length=20)\n",
    "    if dc is not None: out = pd.concat([out, dc.add_prefix('dc_')], axis=1)\n",
    "    # Mass Index\n",
    "    massi = ta.massi(h, l)\n",
    "    if massi is not None: out['massi'] = massi\n",
    "    # ATR trailing stop proxy\n",
    "    out['atr_ratio_14_7'] = out['atr_14'] / out['atr_7'].replace(0, np.nan)\n",
    "\n",
    "    # ── VOLUME ───────────────────────────────────────────────────────────────\n",
    "    out['obv']       = ta.obv(c, v)\n",
    "    out['obv_ema5']  = ta.ema(out['obv'], length=5)\n",
    "    out['obv_vs_ema5'] = out['obv'] / out['obv_ema5'] - 1.0\n",
    "    _ad = ta.ad(h, l, c, v)\n",
    "    if _ad is not None: out['ad'] = _ad\n",
    "    _adosc = ta.adosc(h, l, c, v, fast=3, slow=10)\n",
    "    if _adosc is not None: out['adosc'] = _adosc\n",
    "    _cmf = ta.cmf(h, l, c, v, length=20)\n",
    "    if _cmf is not None: out['cmf_20'] = _cmf\n",
    "    _mfi = ta.mfi(h, l, c, v, length=14)\n",
    "    if _mfi is not None: out['mfi_14'] = _mfi\n",
    "    _efi = ta.efi(c, v, length=13)\n",
    "    if _efi is not None: out['efi_13'] = _efi\n",
    "    _kvo = ta.kvo(h, l, c, v)\n",
    "    if _kvo is not None: out = pd.concat([out, _kvo.add_prefix('kvo_')], axis=1)\n",
    "    # VWAP (intraday reset)\n",
    "    try:\n",
    "        _vwap = ta.vwap(h, l, c, v)\n",
    "        if _vwap is not None:\n",
    "            out['vwap'] = _vwap\n",
    "            out['c_vs_vwap'] = c / out['vwap'] - 1.0\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "    # ── TREND STRENGTH ───────────────────────────────────────────────────────\n",
    "    for length in [7, 14]:\n",
    "        adx = ta.adx(h, l, c, length=length)\n",
    "        if adx is not None:\n",
    "            adx.columns = [f'adx_{length}', f'dmp_{length}', f'dmn_{length}']\n",
    "            out = pd.concat([out, adx], axis=1)\n",
    "    # DI spread: bull/bear pressure\n",
    "    if 'dmp_14' in out.columns and 'dmn_14' in out.columns:\n",
    "        out['di_spread_14'] = out['dmp_14'] - out['dmn_14']\n",
    "\n",
    "    # ── OVERLAP / PRICE ─────────────────────────────────────────────────────\n",
    "    out['midprice_1'] = ta.midprice(h, l, length=1)\n",
    "    out['midpoint_5'] = ta.midpoint(c, length=5)\n",
    "    out['t3_5']       = ta.t3(c, length=5)\n",
    "    out['c_vs_t3_5']  = c / out['t3_5'] - 1.0\n",
    "\n",
    "    # ── ICHIMOKU (tenkan/kijun) ─────────────────────────────────────────────\n",
    "    try:\n",
    "        ichi = ta.ichimoku(h, l, c, tenkan=9, kijun=26, senkou=52)\n",
    "        if ichi is not None and isinstance(ichi, (list, tuple)) and len(ichi) >= 1:\n",
    "            ichi_df = ichi[0]\n",
    "            for col in ['ITS_9', 'IKS_26']:\n",
    "                if col in ichi_df.columns:\n",
    "                    out[col.lower()] = ichi_df[col].values\n",
    "            if 'its_9' in out.columns:\n",
    "                out['c_vs_tenkan'] = c / out['its_9'] - 1.0\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "    # ── NORMALIZE OBV / AD (z-score 50-bar) ─────────────────────────────────\n",
    "    for col in ['obv', 'ad']:\n",
    "        if col in out.columns:\n",
    "            mu  = out[col].rolling(50, min_periods=25).mean()\n",
    "            sig = out[col].rolling(50, min_periods=25).std()\n",
    "            out[f'{col}_zscore_50'] = (out[col] - mu) / sig.replace(0, np.nan)\n",
    "\n",
    "    return out\n",
    "\n",
    "\n",
    "def add_target(df):\n",
    "    out = df.copy(deep=True)\n",
    "    out['next_open']  = out['OPEN'].shift(-1)\n",
    "    out['next_close'] = out['CLOSE'].shift(-1)\n",
    "    out['target_is_green_next'] = (out['next_close'] > out['next_open']).astype('int8')\n",
    "    out = out.drop(columns=['next_open', 'next_close'])\n",
    "    out = out.iloc[:-1].reset_index(drop=True)\n",
    "    return out\n",
    "\n",
    "\n",
    "print('Feature engineering functions defined ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "md-cell4",
   "metadata": {},
   "source": ["## Cell 4 — Master Pipeline Builder"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-4",
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_feature_dataframe(df_raw):\n",
    "    df = prepare_ohlcv_dataframe(df_raw)\n",
    "    df = add_domain_features(df)\n",
    "    df = add_rolling_features(df, windows=(6, 12, 24))\n",
    "    df = add_calendar_features(df)\n",
    "    df = add_ta_features(df)\n",
    "    df = add_target(df)\n",
    "    return df\n",
    "\n",
    "\n",
    "def get_leakage_columns(df):\n",
    "    leakage = ['datetime', 'DATE', 'TIME', 'TICKER', 'PER',\n",
    "               'OPEN', 'HIGH', 'LOW', 'CLOSE', 'VOL']\n",
    "    target_cols = [c for c in df.columns if c.startswith('target_')]\n",
    "    return list(set(leakage + target_cols))\n",
    "\n",
    "\n",
    "def build_X_y_for_model(feature_df, n_in=4):\n",
    "    \"\"\"Build supervised dataset with temporal lag expansion.\n",
    "\n",
    "    n_in=4 means each observation includes features from\n",
    "    the current bar (t) and 3 previous bars (t-1, t-2, t-3).\n",
    "    \"\"\"\n",
    "    leakage_cols = get_leakage_columns(feature_df)\n",
    "    feature_only_cols = [c for c in feature_df.columns if c not in leakage_cols]\n",
    "    X_base = feature_df[feature_only_cols].copy()\n",
    "    y_full = feature_df['target_is_green_next'].copy()\n",
    "\n",
    "    n_raw_features = X_base.shape[1]\n",
    "    print(f'─' * 55)\n",
    "    print(f'Feature count BEFORE series_to_supervised : {n_raw_features}')\n",
    "\n",
    "    valid_idx = X_base.dropna().index\n",
    "    X_clean   = X_base.loc[valid_idx].reset_index(drop=True)\n",
    "    y_clean   = y_full.loc[valid_idx].reset_index(drop=True)\n",
    "\n",
    "    X_supervised = series_to_supervised(X_clean, n_in=n_in, n_out=1, dropnan=True)\n",
    "    y_aligned    = y_clean.iloc[n_in:].reset_index(drop=True)\n",
    "    assert len(X_supervised) == len(y_aligned), \"Length mismatch X vs y\"\n",
    "\n",
    "    n_sup_features = X_supervised.shape[1]\n",
    "    print(f'Lag window (n_in)                          : {n_in}')\n",
    "    print(f'Feature count AFTER  series_to_supervised : {n_sup_features}')\n",
    "    print(f'  = {n_raw_features} raw features x {n_in} lags = {n_raw_features * n_in}')\n",
    "    print(f'Dataset shape after dropna + lag expand   : {X_supervised.shape}')\n",
    "    print(f'─' * 55)\n",
    "\n",
    "    return X_supervised, y_aligned, leakage_cols\n",
    "\n",
    "\n",
    "print('Pipeline builder functions defined ✓')"
   ]
  },
